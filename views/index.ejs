<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Chess Master</title>
  <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;600;700&family=Inter:wght@300;400;500&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --bg: #0d0d0f; --surface: #16161a; --border: #2a2a32;
      --gold: #c9a84c; --gold-dim: #8a6f2e; --text: #e8e6e1; --muted: #6b6b7a;
    }
    body {
      background: var(--bg);
      color: var(--text);
      font-family: 'Inter', sans-serif;
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      padding: 24px;
    }
    body::before {
      content: '';
      position: fixed;
      inset: 0;
      background: radial-gradient(ellipse 60% 60% at 50% 50%, rgba(201,168,76,0.06) 0%, transparent 70%);
      pointer-events: none;
    }
    h1 {
      font-family: 'Cinzel', serif;
      font-size: clamp(1.8rem, 4vw, 2.8rem);
      font-weight: 700;
      letter-spacing: 0.15em;
      color: var(--gold);
      text-shadow: 0 0 40px rgba(201,168,76,0.3);
      text-align: center;
    }
    .subtitle {
      font-size: 0.78rem;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--muted);
      margin-top: 6px;
      margin-bottom: 48px;
      text-align: center;
    }
    .card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 12px;
      padding: 32px;
      width: 100%;
      max-width: 420px;
      display: flex;
      flex-direction: column;
      gap: 24px;
    }
    .section-title {
      font-family: 'Cinzel', serif;
      font-size: 0.7rem;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--gold-dim);
      margin-bottom: 10px;
    }
    button {
      width: 100%;
      padding: 13px;
      background: var(--gold);
      color: #0d0d0f;
      border: none;
      border-radius: 8px;
      font-size: 0.9rem;
      font-weight: 700;
      letter-spacing: 0.08em;
      cursor: pointer;
      font-family: 'Cinzel', serif;
      transition: background 0.2s;
    }
    button:hover { background: #b8973b; }
    button.secondary {
      background: transparent;
      border: 1px solid var(--gold);
      color: var(--gold);
    }
    button.secondary:hover { background: rgba(201,168,76,0.08); }
    input {
      width: 100%;
      padding: 11px 14px;
      background: #0d0d0f;
      border: 1px solid var(--border);
      border-radius: 8px;
      color: var(--text);
      font-size: 0.95rem;
      margin-bottom: 10px;
      outline: none;
      letter-spacing: 0.05em;
    }
    input:focus { border-color: var(--gold); }
    .divider {
      border: none;
      border-top: 1px solid var(--border);
    }
    .nav {
      display: flex;
      gap: 16px;
      justify-content: center;
      margin-top: 24px;
    }
    .nav a {
      font-size: 0.8rem;
      color: var(--muted);
      text-decoration: none;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      transition: color 0.2s;
    }
    .nav a:hover { color: var(--gold); }
    #error {
      color: #e53e3e;
      font-size: 0.83rem;
      text-align: center;
      display: none;
    }
    #username-display {
      text-align: center;
      font-size: 0.85rem;
      color: var(--muted);
      margin-bottom: -12px;
    }
    #username-display span { color: var(--gold); }
  </style>
</head>
<body>
  <h1>CHESS MASTER</h1>
  <p class="subtitle">Real-time multiplayer chess</p>

  <div class="card">
    <div id="username-display">Playing as <span id="uname">...</span></div>

    <div>
      <p class="section-title">New Game</p>
      <button onclick="createRoom()">♟ Create Game</button>
    </div>

    <hr class="divider" />

    <div>
      <p class="section-title">Join Game</p>
      <input type="text" id="room-input" placeholder="Enter room code..." maxlength="8" />
      <button class="secondary" onclick="joinRoom()">→ Join Game</button>
    </div>

    <div id="error"></div>
  </div>

  <nav class="nav">
    <a href="/leaderboard">Leaderboard</a>
    <a href="/login">Switch Account</a>
  </nav>

  <script src="/socket.io/socket.io.js"></script>
  <script>
    // show username
    const username = localStorage.getItem('username')
    if (!username) window.location.href = '/login'
    document.getElementById('uname').textContent = username

    const token = localStorage.getItem('token')
    const socket = io({ auth: { token } })

    socket.on('connect_error', (err) => {
      if (err.message === 'No token provided' || err.message === 'Invalid token') {
        window.location.href = '/login'
      }
    })

    // server created the room → redirect to game page
    socket.on('roomCreated', (roomId) => {
      window.location.href = `/game/${roomId}`
    })

    socket.on('roomError', (msg) => {
      const el = document.getElementById('error')
      el.textContent = msg
      el.style.display = 'block'
    })

    function createRoom() {
      socket.emit('createRoom')
    }

    function joinRoom() {
      const roomId = document.getElementById('room-input').value.trim()
      if (!roomId) return
      socket.emit('joinRoom', roomId)
      // redirect after joining
      socket.once('playerRole', () => {
        window.location.href = `/game/${roomId}`
      })
      socket.once('spectatorRole', () => {
        window.location.href = `/game/${roomId}`
      })
    }

    // allow Enter key to join
    document.getElementById('room-input').addEventListener('keydown', (e) => {
      if (e.key === 'Enter') joinRoom()
    })
  </script>
</body>
</html>