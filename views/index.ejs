<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Chess Master</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;600;700&family=Inter:wght@300;400;500&display=swap"
      rel="stylesheet"
    />
    <style>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

      :root {
        --bg:        #0d0d0f;
        --surface:   #16161a;
        --border:    #2a2a32;
        --gold:      #c9a84c;
        --gold-dim:  #8a6f2e;
        --light-sq:  #f0d9b5;
        --dark-sq:   #b58863;
        --highlight: rgba(201,168,76,0.45);
        --text:      #e8e6e1;
        --muted:     #6b6b7a;
        --check-red: #e53e3e;
        --radius:    10px;
      }

      body {
        background: var(--bg);
        color: var(--text);
        font-family: 'Inter', sans-serif;
        min-height: 100vh;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 24px;
        overflow: hidden;
      }

      body::before {
        content: '';
        position: fixed;
        inset: 0;
        background: radial-gradient(ellipse 60% 60% at 50% 50%, rgba(201,168,76,0.06) 0%, transparent 70%);
        pointer-events: none;
      }

      header {
        text-align: center;
        margin-bottom: 28px;
      }
      header h1 {
        font-family: 'Cinzel', serif;
        font-size: clamp(1.6rem, 4vw, 2.4rem);
        font-weight: 700;
        letter-spacing: 0.12em;
        color: var(--gold);
        text-shadow: 0 0 40px rgba(201,168,76,0.3);
      }
      header p {
        font-size: 0.78rem;
        letter-spacing: 0.2em;
        text-transform: uppercase;
        color: var(--muted);
        margin-top: 4px;
      }

      .game-layout {
        display: flex;
        gap: 24px;
        align-items: flex-start;
        justify-content: center;
      }

      .side-panel {
        width: 200px;
        display: flex;
        flex-direction: column;
        gap: 12px;
      }

      .panel-card {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: var(--radius);
        padding: 16px;
      }

      .panel-card h3 {
        font-family: 'Cinzel', serif;
        font-size: 0.7rem;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        color: var(--gold-dim);
        margin-bottom: 10px;
      }

      #player-role {
        font-size: 0.95rem;
        font-weight: 500;
        color: var(--text);
        line-height: 1.5;
      }

      #status {
        font-size: 0.83rem;
        line-height: 1.5;
        padding: 8px 12px;
        border-radius: 6px;
        border: 1px solid var(--border);
        background: rgba(255,255,255,0.03);
        color: var(--text);
        transition: all 0.3s ease;
        font-weight: 500;
      }
      #status.your-turn  { border-color: var(--gold); color: var(--gold); background: rgba(201,168,76,0.08); }
      #status.waiting    { border-color: var(--border); color: var(--muted); }
      #status.check      { border-color: var(--check-red); color: var(--check-red); background: rgba(229,62,62,0.08); }
      #status.checkmate  { border-color: var(--gold); color: var(--gold); background: rgba(201,168,76,0.15); }
      #status.draw       { border-color: var(--muted); color: var(--muted); }
      #status.spectator  { border-color: var(--border); color: var(--muted); }

      #move-list {
        max-height: 220px;
        overflow-y: auto;
        display: flex;
        flex-direction: column;
        gap: 3px;
        scrollbar-width: thin;
        scrollbar-color: var(--border) transparent;
      }
      .move-entry {
        display: flex;
        gap: 8px;
        font-size: 0.78rem;
        color: var(--muted);
        padding: 3px 0;
        border-bottom: 1px solid rgba(255,255,255,0.04);
      }
      .move-entry .move-num { color: var(--gold-dim); min-width: 20px; }
      .move-entry .move-w   { color: var(--text); min-width: 44px; }
      .move-entry .move-b   { color: var(--text); }

      .board-wrapper {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0;
      }

      .board-outer {
        display: flex;
        flex-direction: row;
        align-items: center;
        gap: 0;
      }

      .rank-labels, .file-labels-container {
        display: flex;
        font-family: 'Cinzel', serif;
        font-size: 0.65rem;
        color: var(--gold-dim);
        letter-spacing: 0.05em;
        user-select: none;
      }
      .rank-labels {
        flex-direction: column;
        width: 18px;
      }
      .rank-labels span {
        display: flex;
        align-items: center;
        justify-content: center;
        height: calc(min(80vw, 520px) / 8);
      }

      .file-labels-container {
        flex-direction: row;
        margin-left: 18px;
        margin-top: 4px;
      }
      .file-label {
        display: flex;
        align-items: center;
        justify-content: center;
        width: calc(min(80vw, 520px) / 8);
      }

      .chessboard {
        display: grid;
        grid-template-columns: repeat(8, 1fr);
        grid-template-rows: repeat(8, 1fr);
        width: min(80vw, 520px);
        height: min(80vw, 520px);
        border: 3px solid var(--gold-dim);
        border-radius: 4px;
        box-shadow:
          0 0 0 1px rgba(201,168,76,0.15),
          0 24px 80px rgba(0,0,0,0.7),
          inset 0 0 0 1px rgba(255,255,255,0.03);
        overflow: hidden;
      }

      .square {
        display: flex;
        align-items: center;
        justify-content: center;
        position: relative;
        transition: background 0.15s;
      }
      .square.light { background-color: var(--light-sq); }
      .square.dark  { background-color: var(--dark-sq); }
      .square.highlight   { background-color: var(--highlight) !important; }
      .square.last-from   { box-shadow: inset 0 0 0 3px rgba(201,168,76,0.5); }
      .square.last-to     { box-shadow: inset 0 0 0 3px rgba(201,168,76,0.7); }
      .square.can-capture::after {
        content: '';
        position: absolute;
        inset: 0;
        border-radius: 50%;
        border: 4px solid rgba(0,0,0,0.2);
        pointer-events: none;
        z-index: 1;
      }

      .piece {
        font-size: clamp(24px, 5.5vw, 44px);
        cursor: default;
        user-select: none;
        line-height: 1;
        transition: transform 0.1s ease, filter 0.1s ease;
        position: relative;
        z-index: 2;
      }
      .piece.white {
        color: #fff;
        filter: drop-shadow(0 1px 3px rgba(0,0,0,0.9)) drop-shadow(0 0 1px rgba(0,0,0,1));
      }
      .piece.black {
        color: #1a1a1a;
        filter: drop-shadow(0 1px 3px rgba(0,0,0,0.6));
      }
      .piece[draggable="true"] { cursor: grab; }
      .piece[draggable="true"]:hover {
        transform: scale(1.12);
        filter: drop-shadow(0 4px 8px rgba(0,0,0,0.8)) drop-shadow(0 0 12px rgba(201,168,76,0.4));
      }
      .piece.dragging {
        opacity: 0.35;
        transform: scale(0.9);
        cursor: grabbing;
      }

      .move-dot {
        position: absolute;
        width: 30%;
        height: 30%;
        border-radius: 50%;
        background: rgba(0,0,0,0.22);
        pointer-events: none;
        z-index: 1;
      }

      @keyframes shake {
        0%, 100% { transform: translateX(0); }
        20%       { transform: translateX(-6px); }
        40%       { transform: translateX(6px); }
        60%       { transform: translateX(-4px); }
        80%       { transform: translateX(4px); }
      }
      .shake { animation: shake 0.4s ease; }

      @media (max-width: 700px) {
        .game-layout { flex-direction: column; align-items: center; }
        .side-panel { width: min(80vw, 520px); flex-direction: row; flex-wrap: wrap; }
        .panel-card { flex: 1; min-width: 140px; }
        #move-list { max-height: 120px; }
      }
    </style>
  </head>
  <body>
    <header>
      <h1>CHESS MASTER</h1>
      <p>Two-Player Online Chess</p>
    </header>

    <div class="game-layout">
      <!-- Left panel -->
      <div class="side-panel">
        <div class="panel-card">
          <h3>You are</h3>
          <div id="player-role">Connecting…</div>
        </div>
        <div class="panel-card">
          <h3>Status</h3>
          <div id="status" class="waiting">Waiting for opponent…</div>
        </div>
      </div>

      <!-- Board -->
      <div class="board-wrapper">
        <div class="board-outer">
          <div class="rank-labels" id="rank-labels">
            <span>8</span><span>7</span><span>6</span><span>5</span>
            <span>4</span><span>3</span><span>2</span><span>1</span>
          </div>
          <div class="chessboard" id="chessboard"></div>
        </div>
        <div class="file-labels-container" id="file-labels">
          <span class="file-label">a</span><span class="file-label">b</span>
          <span class="file-label">c</span><span class="file-label">d</span>
          <span class="file-label">e</span><span class="file-label">f</span>
          <span class="file-label">g</span><span class="file-label">h</span>
        </div>
      </div>

      <!-- Right panel -->
      <div class="side-panel">
        <div class="panel-card">
          <h3>Move History</h3>
          <div id="move-list"></div>
        </div>
      </div>
    </div>

    <script src="/socket.io/socket.io.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/chess.js/0.10.3/chess.min.js"></script>
    <script src="/js/main.js"></script>
    <script src="/views/leaderboard.js"></script>
  </body>
</html>